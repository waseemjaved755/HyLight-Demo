APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# Dev/ngrok: set true to allow all origins (*) — do NOT use in production
CORS_ALLOW_ALL=false

# Recommended — copy from Supabase Connect → Python → Transaction pooler
DATABASE_HOST=aws-1-eu-central-1.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.YOUR_PROJECT_REF
DATABASE_PASSWORD=your-database-password

# Alternative — full URI from Supabase (password must be URL-encoded; @ → %40)
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:your-password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_URL=https://your-project.supabase.co
# Optional — only needed if AI runs without a client signed URL (legacy service_role JWT or sb_secret_...)
# SUPABASE_SERVICE_ROLE_KEY=your-secret-key
# SUPABASE_SECRET_KEY=sb_secret_...
STORAGE_BUCKET=Photos

# Google Gemini for auto descriptions (required for AI)
GEMINI_API_KEY=
# Free tier: use gemini-2.5-flash (gemini-2.0-flash often returns 429 quota errors)
GEMINI_MODEL=gemini-2.5-flash

REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
